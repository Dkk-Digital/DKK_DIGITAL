# Copy this file to .env and fill in the real values.
# Use a STANDARD (non-SRV) MongoDB connection string if your network blocks SRV DNS lookups.
# Example standard (replace hosts/credentials with values from Atlas "Standard connection string"):
# MONGODB_URI=mongodb://<username>:<password>@host0.example.net:27017,host1.example.net:27017/<dbname>?replicaSet=<rs>&authSource=admin&retryWrites=true&w=majority

# Or, if your environment supports SRV lookups, use the mongodb+srv URI (Atlas default):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.pxsjump.mongodb.net/<dbname>?retryWrites=true&w=majority

MONGODB_URI=
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
PORT=5000
CLIENT_URL=http://localhost:3000

# SMTP (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Cloudinary
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin seeding credentials (optional)
ADMIN_EMAIL=admin@dkkdigital.com
ADMIN_PASSWORD=Admin@123
